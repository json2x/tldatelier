# Auto detect text files and perform LF normalization
* text=auto

# JS/TS
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf

# Styles
*.css text eol=lf

# Config
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf

# Markdown
*.md text eol=lf

# Lock files - don't diff
package-lock.json -diff linguist-generated=true
pnpm-lock.yaml -diff linguist-generated=true
yarn.lock -diff linguist-generated=true

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text eol=lf
*.webp binary
*.avif binary

# Fonts
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary

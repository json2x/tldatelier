# AI Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Active AI provider: "openai" or "claude"
AI_PROVIDER=openai

# ── Domain Availability Provider ──────────────────────────────────────────────
# Which provider to use for domain availability checks.
# Options: "namecheap" | "godaddy"
# If the selected provider's credentials are missing, availability returns null.
DOMAIN_PROVIDER=godaddy

# GoDaddy API (use OTE sandbox for testing, production for live)
# OTE sandbox base URL : https://api.ote-godaddy.com
# Production base URL  : https://api.godaddy.com
GODADDY_API_KEY=
GODADDY_API_SECRET=
GODADDY_BASE_URL=https://api.ote-godaddy.com

# Namecheap API (domain availability)
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_USERNAME=
NAMECHEAP_CLIENT_IP=

# Affiliate link base URL (used on every "Buy Domain" button)
NAMECHEAP_AFFILIATE_LINK=https://www.namecheap.com/domains/registration/results/?domain=
